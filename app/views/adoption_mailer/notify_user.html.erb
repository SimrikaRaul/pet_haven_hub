<% # User notification email for adoption status changes %>

<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
  <!-- Status-specific header -->
  <tr>
    <td style="padding-bottom: 24px;">
      <% case @status %>
      <% when 'approved' %>
        <table role="presentation" cellspacing="0" cellpadding="0" border="0">
          <tr>
            <td style="background-color: #d1fae5; color: #065f46; padding: 8px 16px; border-radius: 20px; font-size: 13px; font-weight: 600;">
              Request Approved
            </td>
          </tr>
        </table>
      <% when 'rejected' %>
        <table role="presentation" cellspacing="0" cellpadding="0" border="0">
          <tr>
            <td style="background-color: #fee2e2; color: #991b1b; padding: 8px 16px; border-radius: 20px; font-size: 13px; font-weight: 600;">
              Request Not Approved
            </td>
          </tr>
        </table>
      <% when 'completed' %>
        <table role="presentation" cellspacing="0" cellpadding="0" border="0">
          <tr>
            <td style="background-color: #dbeafe; color: #1e40af; padding: 8px 16px; border-radius: 20px; font-size: 13px; font-weight: 600;">
              Adoption Complete
            </td>
          </tr>
        </table>
      <% else %>
        <table role="presentation" cellspacing="0" cellpadding="0" border="0">
          <tr>
            <td style="background-color: #fef3c7; color: #92400e; padding: 8px 16px; border-radius: 20px; font-size: 13px; font-weight: 600;">
              Status Update
            </td>
          </tr>
        </table>
      <% end %>
    </td>
  </tr>

  <!-- Greeting -->
  <tr>
    <td style="padding-bottom: 20px;">
      <h2 style="margin: 0; font-size: 22px; font-weight: 600; color: #1f2937;">
        Hello, <%= @user&.name || 'Valued Member' %>!
      </h2>
    </td>
  </tr>

  <!-- Status-specific message -->
  <tr>
    <td style="padding-bottom: 24px;">
      <% case @status %>
      <% when 'approved' %>
        <p style="margin: 0; font-size: 15px; line-height: 1.6; color: #4b5563;">
          Great news! Your adoption request for <strong><%= @pet&.name || 'the pet' %></strong> has been
          <span style="color: #059669; font-weight: 600;">approved</span>!
          We're thrilled to help you welcome a new furry friend into your family.
        </p>
      <% when 'rejected' %>
        <p style="margin: 0; font-size: 15px; line-height: 1.6; color: #4b5563;">
          We've reviewed your adoption request for <strong><%= @pet&.name || 'the pet' %></strong>,
          and unfortunately, we're unable to approve it at this time.
        </p>
      <% when 'completed' %>
        <p style="margin: 0; font-size: 15px; line-height: 1.6; color: #4b5563;">
          Congratulations! The adoption process for <strong><%= @pet&.name || 'your new pet' %></strong>
          is now complete. We're so happy that <%= @pet&.name || 'they' %> has found a loving forever home with you!
        </p>
      <% else %>
        <p style="margin: 0; font-size: 15px; line-height: 1.6; color: #4b5563;">
          There's been an update to your adoption request for <strong><%= @pet&.name || 'the pet' %></strong>.
        </p>
      <% end %>
    </td>
  </tr>

  <!-- Pet Info Card -->
  <tr>
    <td style="padding-bottom: 24px;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f9fafb; border-radius: 8px; border: 1px solid #e5e7eb;">
        <tr>
          <td style="padding: 24px;">
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
              <tr>
                <td>
                  <p style="margin: 0 0 4px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: #6b7280; font-weight: 600;">Pet Details</p>
                  <p style="margin: 0; font-size: 20px; font-weight: 600; color: #1f2937;"><%= @pet&.name || 'Unknown Pet' %></p>
                  <p style="margin: 8px 0 0; font-size: 14px; color: #4b5563;">
                    <%= @pet&.pet_type&.capitalize || 'Pet' %>
                    <% if @pet&.breed.present? %> &bull; <%= @pet.breed %><% end %>
                    <% if @pet&.age.present? %> &bull; <%= @pet.age %> years old<% end %>
                    <% if @pet&.sex.present? %> &bull; <%= @pet.sex.capitalize %><% end %>
                  </p>
                </td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <% if @status == 'approved' %>
    <!-- Next Steps for Approved -->
    <tr>
      <td style="padding-bottom: 24px;">
        <h3 style="margin: 0 0 16px; font-size: 16px; font-weight: 600; color: #1f2937;">What's Next?</h3>
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
          <tr>
            <td style="padding: 12px 0; border-bottom: 1px solid #e5e7eb;">
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                <tr>
                  <td width="32" style="vertical-align: top;">
                    <span style="display: inline-block; width: 24px; height: 24px; background-color: #667eea; color: #ffffff; border-radius: 50%; text-align: center; line-height: 24px; font-size: 12px; font-weight: 600;">1</span>
                  </td>
                  <td style="vertical-align: top;">
                    <p style="margin: 0; font-size: 14px; color: #1f2937; font-weight: 500;">Schedule a Visit</p>
                    <p style="margin: 4px 0 0; font-size: 13px; color: #6b7280;">Contact us to arrange a time to meet <%= @pet&.name || 'your new pet' %>.</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="padding: 12px 0; border-bottom: 1px solid #e5e7eb;">
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                <tr>
                  <td width="32" style="vertical-align: top;">
                    <span style="display: inline-block; width: 24px; height: 24px; background-color: #667eea; color: #ffffff; border-radius: 50%; text-align: center; line-height: 24px; font-size: 12px; font-weight: 600;">2</span>
                  </td>
                  <td style="vertical-align: top;">
                    <p style="margin: 0; font-size: 14px; color: #1f2937; font-weight: 500;">Complete Paperwork</p>
                    <p style="margin: 4px 0 0; font-size: 13px; color: #6b7280;">Bring your ID and complete the adoption agreement.</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="padding: 12px 0;">
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                <tr>
                  <td width="32" style="vertical-align: top;">
                    <span style="display: inline-block; width: 24px; height: 24px; background-color: #667eea; color: #ffffff; border-radius: 50%; text-align: center; line-height: 24px; font-size: 12px; font-weight: 600;">3</span>
                  </td>
                  <td style="vertical-align: top;">
                    <p style="margin: 0; font-size: 14px; color: #1f2937; font-weight: 500;">Welcome Home!</p>
                    <p style="margin: 4px 0 0; font-size: 13px; color: #6b7280;">Take <%= @pet&.name || 'your new friend' %> to their forever home.</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  <% end %>

  <% if @status == 'rejected' && @rejection_reason.present? %>
    <!-- Rejection Reason -->
    <tr>
      <td style="padding-bottom: 24px;">
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #fef2f2; border-radius: 8px; border: 1px solid #fecaca;">
          <tr>
            <td style="padding: 20px;">
              <p style="margin: 0 0 8px; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px; color: #991b1b; font-weight: 600;">Reason</p>
              <p style="margin: 0; font-size: 14px; line-height: 1.6; color: #7f1d1d;">
                <%= @rejection_reason %>
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>

    <!-- Encouragement message -->
    <tr>
      <td style="padding-bottom: 24px;">
        <p style="margin: 0; font-size: 15px; line-height: 1.6; color: #4b5563;">
          Don't be discouraged! There are many other wonderful pets looking for loving homes.
          We encourage you to browse our available pets and find your perfect match.
        </p>
      </td>
    </tr>
  <% end %>

  <% if @status == 'completed' %>
    <!-- Completion Tips -->
    <tr>
      <td style="padding-bottom: 24px;">
        <h3 style="margin: 0 0 16px; font-size: 16px; font-weight: 600; color: #1f2937;">Tips for the First Week</h3>
        <ul style="margin: 0; padding-left: 20px; font-size: 14px; line-height: 1.8; color: #4b5563;">
          <li>Give <%= @pet&.name || 'your pet' %> time to adjust to the new environment</li>
          <li>Keep a consistent routine for feeding and walks</li>
          <li>Schedule a vet check-up within the first week</li>
          <li>Introduce family members and other pets gradually</li>
        </ul>
      </td>
    </tr>
  <% end %>

  <!-- CTA Button -->
  <tr>
    <td style="padding-bottom: 24px;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0">
        <tr>
          <% if @status == 'rejected' %>
            <td style="border-radius: 6px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
              <a href="<%= pets_url %>" target="_blank" style="display: inline-block; padding: 14px 28px; font-size: 15px; font-weight: 600; color: #ffffff; text-decoration: none;">
                Browse Available Pets
              </a>
            </td>
          <% elsif @pet_url.present? %>
            <td style="border-radius: 6px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
              <a href="<%= @pet_url %>" target="_blank" style="display: inline-block; padding: 14px 28px; font-size: 15px; font-weight: 600; color: #ffffff; text-decoration: none;">
                View <%= @pet&.name || 'Pet' %>'s Profile
              </a>
            </td>
          <% end %>
        </tr>
      </table>
    </td>
  </tr>

  <!-- Closing -->
  <tr>
    <td>
      <p style="margin: 0; font-size: 14px; line-height: 1.6; color: #4b5563;">
        <% if @status == 'approved' || @status == 'completed' %>
          Thank you for choosing to adopt! You're making a real difference in a pet's life.
        <% else %>
          If you have any questions, please don't hesitate to contact us.
        <% end %>
      </p>
      <p style="margin: 16px 0 0; font-size: 14px; color: #4b5563;">
        Warm regards,<br>
        <strong style="color: #1f2937;">The Pet Haven Hub Team</strong>
      </p>
    </td>
  </tr>
</table>
