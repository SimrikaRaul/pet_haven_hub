<% # Admin notification email for new adoption requests %>

<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
  <!-- Alert Badge -->
  <tr>
    <td style="padding-bottom: 24px;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0">
        <tr>
          <td style="background-color: #fef3c7; color: #92400e; padding: 8px 16px; border-radius: 20px; font-size: 13px; font-weight: 600;">
            New Request Requires Review
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- Greeting -->
  <tr>
    <td style="padding-bottom: 20px;">
      <h2 style="margin: 0; font-size: 22px; font-weight: 600; color: #1f2937;">
        New Adoption Request Received
      </h2>
    </td>
  </tr>

  <!-- Introduction -->
  <tr>
    <td style="padding-bottom: 24px;">
      <p style="margin: 0; font-size: 15px; line-height: 1.6; color: #4b5563;">
        A new adoption request has been submitted and requires your review. Please find the details below.
      </p>
    </td>
  </tr>

  <!-- Request Details Card -->
  <tr>
    <td style="padding-bottom: 24px;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f9fafb; border-radius: 8px; border: 1px solid #e5e7eb;">
        <tr>
          <td style="padding: 24px;">
            <!-- Pet Info -->
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 20px;">
              <tr>
                <td>
                  <p style="margin: 0 0 4px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: #6b7280; font-weight: 600;">Pet Information</p>
                  <p style="margin: 0; font-size: 18px; font-weight: 600; color: #1f2937;"><%= @pet&.name || 'Unknown Pet' %></p>
                  <p style="margin: 4px 0 0; font-size: 14px; color: #4b5563;">
                    <%= @pet&.pet_type&.capitalize || 'Unknown' %>
                    <% if @pet&.breed.present? %>| <%= @pet.breed %><% end %>
                    <% if @pet&.age.present? %>| <%= @pet.age %> years old<% end %>
                  </p>
                </td>
              </tr>
            </table>

            <hr style="border: none; border-top: 1px solid #e5e7eb; margin: 16px 0;">

            <!-- Requester Info -->
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 16px;">
              <tr>
                <td>
                  <p style="margin: 0 0 4px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: #6b7280; font-weight: 600;">Requester Details</p>
                  <p style="margin: 0; font-size: 16px; font-weight: 500; color: #1f2937;"><%= @user&.name || 'Unknown User' %></p>
                  <p style="margin: 4px 0 0; font-size: 14px; color: #4b5563;"><%= @user&.email || 'No email provided' %></p>
                  <% if @request&.phone_number.present? %>
                    <p style="margin: 4px 0 0; font-size: 14px; color: #4b5563;">Phone: <%= @request.phone_number %></p>
                  <% end %>
                </td>
              </tr>
            </table>

            <!-- Request Details -->
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
              <tr>
                <td width="50%" style="padding-right: 12px; vertical-align: top;">
                  <p style="margin: 0 0 4px; font-size: 12px; color: #6b7280;">Request Type</p>
                  <p style="margin: 0; font-size: 14px; font-weight: 500; color: #1f2937;"><%= @request&.request_type&.capitalize || 'Adoption' %></p>
                </td>
                <td width="50%" style="vertical-align: top;">
                  <p style="margin: 0 0 4px; font-size: 12px; color: #6b7280;">Submitted</p>
                  <p style="margin: 0; font-size: 14px; font-weight: 500; color: #1f2937;"><%= @request&.created_at&.strftime('%B %d, %Y at %I:%M %p') || 'Unknown' %></p>
                </td>
              </tr>
              <% if @request&.house_type.present? %>
                <tr>
                  <td colspan="2" style="padding-top: 12px;">
                    <p style="margin: 0 0 4px; font-size: 12px; color: #6b7280;">Housing Type</p>
                    <p style="margin: 0; font-size: 14px; font-weight: 500; color: #1f2937;"><%= @request.house_type.humanize %></p>
                  </td>
                </tr>
              <% end %>
            </table>

            <% if @request&.reason.present? %>
              <hr style="border: none; border-top: 1px solid #e5e7eb; margin: 16px 0;">
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                <tr>
                  <td>
                    <p style="margin: 0 0 8px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: #6b7280; font-weight: 600;">Reason for Adoption</p>
                    <p style="margin: 0; font-size: 14px; line-height: 1.6; color: #4b5563; background-color: #ffffff; padding: 12px; border-radius: 6px; border: 1px solid #e5e7eb;">
                      <%= truncate(@request.reason, length: 300) %>
                    </p>
                  </td>
                </tr>
              </table>
            <% end %>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- Status Badge -->
  <tr>
    <td style="padding-bottom: 24px;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0">
        <tr>
          <td style="padding-right: 8px;">
            <span style="display: inline-block; background-color: #dbeafe; color: #1e40af; padding: 6px 12px; border-radius: 4px; font-size: 13px; font-weight: 500;">
              Status: <%= @request&.status&.humanize || 'Open' %>
            </span>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- CTA Button -->
  <tr>
    <td style="padding-bottom: 24px;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0">
        <tr>
          <td style="border-radius: 6px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <a href="<%= @admin_dashboard_url %>" target="_blank" style="display: inline-block; padding: 14px 28px; font-size: 15px; font-weight: 600; color: #ffffff; text-decoration: none;">
              Review Request in Dashboard
            </a>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- Additional Info -->
  <tr>
    <td>
      <p style="margin: 0; font-size: 13px; line-height: 1.6; color: #6b7280;">
        This request requires your review before the adoption process can proceed. Please log in to the admin dashboard to approve or reject this request.
      </p>
    </td>
  </tr>
</table>
