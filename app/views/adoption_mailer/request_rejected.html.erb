<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; background-color: #f3f4f6;">
  <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f3f4f6;">
    <tr>
      <td style="padding: 20px; text-align: center;">
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
          <tr>
            <td style="background: linear-gradient(135deg, #4F46E5 0%, #6366f1 100%); padding: 40px 20px; text-align: center; border-radius: 8px 8px 0 0;">
              <h1 style="margin: 0; color: #ffffff; font-size: 28px; font-weight: 700;">Update on Your Request</h1>
              <p style="margin: 8px 0 0; color: rgba(255,255,255,0.9); font-size: 14px;">For <%= @pet&.name %></p>
            </td>
          </tr>
          <tr>
            <td style="padding: 40px 30px;">
              <h2 style="margin: 0 0 20px; color: #1f2937; font-size: 24px; font-weight: 600;">
                Hello, <%= @user.name %>
              </h2>
              <p style="margin: 0 0 24px; color: #4b5563; font-size: 16px; line-height: 1.6;">
                We've reviewed your adoption request for <strong><%= @pet&.name %></strong>, and unfortunately,
                we're unable to approve it at this time.
              </p>
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f3f4f6; border-radius: 6px; border-left: 4px solid #4F46E5; margin-bottom: 24px;">
                <tr>
                  <td style="padding: 20px;">
                    <p style="margin: 0 0 8px; color: #6b7280; font-size: 12px; font-weight: 600; text-transform: uppercase;">Pet</p>
                    <p style="margin: 0; color: #1f2937; font-size: 16px; font-weight: 600;"><%= @pet&.name %></p>
                  </td>
                </tr>
              </table>
              <% if @rejection_reason.present? %>
                <p style="margin: 0 0 12px; color: #1f2937; font-size: 14px; font-weight: 600;">Reason for Decision</p>
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #fee2e2; border-radius: 6px; border-left: 4px solid #dc2626; margin-bottom: 24px;">
                  <tr>
                    <td style="padding: 20px;">
                      <p style="margin: 0; color: #7f1d1d; font-size: 14px; line-height: 1.6;">
                        <%= @rejection_reason %>
                      </p>
                    </td>
                  </tr>
                </table>
              <% end %>
              <p style="margin: 0 0 24px; color: #4b5563; font-size: 14px; line-height: 1.6;">
                Don't be discouraged! There are many wonderful pets looking for loving homes.
                We encourage you to browse our available pets and find your perfect match.
              </p>
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 30px;">
                <tr>
                  <td style="text-align: center;">
                    <a href="<%= pets_url %>" style="display: inline-block; padding: 14px 32px; background: linear-gradient(135deg, #4F46E5 0%, #6366f1 100%); color: #ffffff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 14px;">
                      Browse Available Pets
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="background-color: #f9fafb; padding: 30px; border-radius: 0 0 8px 8px; border-top: 1px solid #e5e7eb;">
              <p style="margin: 0 0 12px; color: #6b7280; font-size: 14px; line-height: 1.6;">
                <strong style="color: #1f2937;">Pet Haven Hub</strong><br>
                Panauti, Kathmandu, Nepal
              </p>
              <p style="margin: 0 0 12px; color: #6b7280; font-size: 12px;">
                © <%= Time.current.year %> Pet Haven Hub. All rights reserved.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
