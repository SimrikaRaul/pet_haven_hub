<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; background-color: #f3f4f6;">
  <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f3f4f6;">
    <tr>
      <td style="padding: 20px; text-align: center;">
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
          <tr>
            <td style="background: linear-gradient(135deg, #059669 0%, #10b981 100%); padding: 40px 20px; text-align: center; border-radius: 8px 8px 0 0;">
              <h1 style="margin: 0; color: #ffffff; font-size: 32px; font-weight: 700;">🎉 Great News!</h1>
              <p style="margin: 8px 0 0; color: rgba(255,255,255,0.9); font-size: 14px;">Your Adoption Request Has Been Approved</p>
            </td>
          </tr>
          <tr>
            <td style="padding: 40px 30px;">
              <h2 style="margin: 0 0 20px; color: #1f2937; font-size: 24px; font-weight: 600;">
                Congratulations, <%= @user.name %>!
              </h2>
              <p style="margin: 0 0 24px; color: #4b5563; font-size: 16px; line-height: 1.6;">
                We're thrilled to inform you that your adoption request for <strong style="color: #059669;"><%= @pet&.name %></strong> has been <strong>APPROVED</strong>! 🎉
              </p>
              
              <!-- Pet Details Card -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f0fdf4; border-radius: 6px; border-left: 4px solid #059669; margin-bottom: 30px;">
                <tr>
                  <td style="padding: 20px;">
                    <p style="margin: 0 0 12px; color: #1f2937; font-size: 18px; font-weight: 600;"><%= @pet&.name %></p>
                    <p style="margin: 0; color: #4b5563; font-size: 14px;">
                      <%= @pet&.pet_type&.capitalize %><% if @pet&.breed.present? %> • <%= @pet.breed %><% end %><% if @pet&.age.present? %> • <%= @pet.age %> years<% end %>
                    </p>
                  </td>
                </tr>
              </table>

              <% if @adoption_date.present? %>
                <!-- Adoption Date Card -->
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #eff6ff; border-radius: 6px; border-left: 4px solid #0284c7; margin-bottom: 30px;">
                  <tr>
                    <td style="padding: 20px;">
                      <p style="margin: 0 0 8px; color: #0c4a6e; font-size: 14px; font-weight: 600;">📅 Scheduled Adoption Pickup Date</p>
                      <p style="margin: 0; color: #0c4a6e; font-size: 18px; font-weight: 700;">
                        <%= @adoption_date.strftime('%A, %B %-d, %Y') %>
                      </p>
                    </td>
                  </tr>
                </table>
              <% end %>

              <% if @admin_note.present? %>
                <!-- Admin Instructions Card -->
                <div style="background-color: #fef8ee; border-radius: 6px; border-left: 4px solid #d97706; margin-bottom: 30px;">
                  <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                    <tr>
                      <td style="padding: 20px;">
                        <p style="margin: 0 0 12px; color: #92400e; font-size: 14px; font-weight: 600;">📝 Important Instructions from Our Team</p>
                        <p style="margin: 0; color: #92400e; font-size: 14px; line-height: 1.6; white-space: pre-wrap;">
                          <%= @admin_note %>
                        </p>
                      </td>
                    </tr>
                  </table>
                </div>
              <% end %>

              <!-- Adoption Center Location Card -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #eff6ff; border-radius: 6px; border-left: 4px solid #0284c7; margin-bottom: 30px;">
                <tr>
                  <td style="padding: 20px;">
                    <p style="margin: 0 0 12px; color: #0c4a6e; font-size: 14px; font-weight: 600;">📍 Adoption Center Location</p>
                    <p style="margin: 0; color: #0c4a6e; font-size: 14px; line-height: 1.8;">
                      <strong style="font-size: 15px;"><%= @adoption_center_name %></strong><br>
                      <%= @adoption_center_location %>
                    </p>
                  </td>
                </tr>
              </table>

              <p style="margin: 0 0 16px; color: #1f2937; font-size: 16px; font-weight: 600;">Next Steps</p>
              <ol style="margin: 0 0 24px; padding-left: 20px; color: #4b5563; font-size: 14px; line-height: 1.8;">
                <% if @adoption_date.present? %>
                  <li style="margin-bottom: 10px;">Mark your calendar for <%= @adoption_date.strftime('%B %-d, %Y') %></li>
                  <li style="margin-bottom: 10px;">Review the instructions above and prepare needed items</li>
                  <li style="margin-bottom: 10px;">Arrive a few minutes early for your pickup appointment</li>
                  <li>Complete final paperwork and welcome <%= @pet&.name %> home!</li>
                <% else %>
                  <li style="margin-bottom: 10px;">We'll contact you to schedule a meeting with <%= @pet&.name %></li>
                  <li style="margin-bottom: 10px;">Complete any final paperwork required</li>
                  <li style="margin-bottom: 10px;">Finalize the adoption agreement</li>
                  <li>Welcome your new family member home!</li>
                <% end %>
              </ol>

              <% unless @adoption_date.present? %>
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #fef3c7; border-radius: 6px; border-left: 4px solid #d97706; margin-bottom: 30px;">
                  <tr>
                    <td style="padding: 20px;">
                      <p style="margin: 0 0 8px; color: #92400e; font-size: 14px; font-weight: 600;">⏰ Expected Timeline</p>
                      <p style="margin: 0; color: #92400e; font-size: 14px; line-height: 1.6;">
                        We'll reach out within 24-48 hours. The adoption process typically takes 1-2 weeks.
                      </p>
                    </td>
                  </tr>
                </table>
              <% end %>

              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 30px;">
                <tr>
                  <td style="text-align: center;">
                    <a href="<%= requests_url %>" style="display: inline-block; padding: 14px 32px; background: linear-gradient(135deg, #059669 0%, #10b981 100%); color: #ffffff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 14px;">
                      View Request Details
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="background-color: #f9fafb; padding: 30px; border-radius: 0 0 8px 8px; border-top: 1px solid #e5e7eb;">
              <p style="margin: 0 0 12px; color: #6b7280; font-size: 14px; line-height: 1.6;">
                <strong style="color: #1f2937;">Pet Haven Hub</strong><br>
                Panauti, Kathmandu, Nepal
              </p>
              <p style="margin: 0 0 12px; color: #6b7280; font-size: 12px;">
                © <%= Time.current.year %> Pet Haven Hub. All rights reserved.
              </p>
              <p style="margin: 0; color: #6b7280; font-size: 12px;">
                Questions? Contact us at support@petuheaven.com
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
