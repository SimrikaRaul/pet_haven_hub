<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; background-color: #f3f4f6;">
  <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f3f4f6;">
    <tr>
      <td style="padding: 20px; text-align: center;">
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
          <tr>
            <td style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); padding: 40px 20px; text-align: center; border-radius: 8px 8px 0 0;">
              <h1 style="margin: 0; color: #ffffff; font-size: 32px; font-weight: 700;">📅 Adoption Rescheduled</h1>
              <p style="margin: 8px 0 0; color: rgba(255,255,255,0.9); font-size: 14px;">New Pickup Date Scheduled</p>
            </td>
          </tr>
          <tr>
            <td style="padding: 40px 30px;">
              <h2 style="margin: 0 0 20px; color: #1f2937; font-size: 24px; font-weight: 600;">
                New Adoption Date Scheduled
              </h2>
              <p style="margin: 0 0 24px; color: #4b5563; font-size: 16px; line-height: 1.6;">
                Great news! Your adoption for <strong style="color: #6366f1;"><%= @pet&.name %></strong> has been rescheduled to a new date. Please review the details below carefully.
              </p>

              <!-- Pet Details Card -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #e0e7ff; border-radius: 6px; border-left: 4px solid #6366f1; margin-bottom: 30px;">
                <tr>
                  <td style="padding: 20px;">
                    <p style="margin: 0 0 12px; color: #1f2937; font-size: 18px; font-weight: 600;"><%= @pet&.name %></p>
                    <p style="margin: 0; color: #4b5563; font-size: 14px;">
                      <%= @pet&.pet_type&.capitalize %><% if @pet&.breed.present? %> • <%= @pet.breed %><% end %><% if @pet&.age.present? %> • <%= @pet.age %> years<% end %>
                    </p>
                  </td>
                </tr>
              </table>

              <!-- New Adoption Date Card -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #eff6ff; border-radius: 6px; border-left: 4px solid #0284c7; margin-bottom: 30px;">
                <tr>
                  <td style="padding: 20px;">
                    <p style="margin: 0 0 8px; color: #0c4a6e; font-size: 14px; font-weight: 600;">📅 New Adoption Pickup Date</p>
                    <p style="margin: 0; color: #0c4a6e; font-size: 18px; font-weight: 700;">
                      <%= @adoption_date.strftime('%A, %B %-d, %Y') %>
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Reschedule Count Warning -->
              <% if @reschedule_count == 2 %>
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #fef2f2; border-radius: 6px; border-left: 4px solid #dc2626; margin-bottom: 30px;">
                  <tr>
                    <td style="padding: 20px;">
                      <p style="margin: 0 0 12px; color: #991b1b; font-size: 14px; font-weight: 600;">⚠️ Final Rescheduling Opportunity</p>
                      <p style="margin: 0; color: #991b1b; font-size: 14px; line-height: 1.6;">
                        This is your final rescheduling opportunity. If you are unable to attend this new appointment, your adoption request will be automatically rejected. Please make sure you can commit to this date before confirming.
                      </p>
                    </td>
                  </tr>
                </table>
              <% elsif @reschedule_count == 1 %>
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #fff7ed; border-radius: 6px; border-left: 4px solid #f97316; margin-bottom: 30px;">
                  <tr>
                    <td style="padding: 20px;">
                      <p style="margin: 0 0 12px; color: #92400e; font-size: 14px; font-weight: 600;">📝 Important Reminder</p>
                      <p style="margin: 0; color: #92400e; font-size: 14px; line-height: 1.6;">
                        You have already used one reschedule opportunity. This is your second and final reschedule. If you cannot make this appointment, your adoption request will be rejected.
                      </p>
                    </td>
                  </tr>
                </table>
              <% end %>

              <% if @admin_note.present? %>
                <!-- Admin Instructions Card -->
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #fef8ee; border-radius: 6px; border-left: 4px solid #d97706; margin-bottom: 30px;">
                  <tr>
                    <td style="padding: 20px;">
                      <p style="margin: 0 0 12px; color: #92400e; font-size: 14px; font-weight: 600;">📝 Important Instructions</p>
                      <p style="margin: 0; color: #92400e; font-size: 14px; line-height: 1.6; white-space: pre-wrap;">
                        <%= @admin_note %>
                      </p>
                    </td>
                  </tr>
                </table>
              <% end %>

              <!-- Adoption Center Location Card -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #eff6ff; border-radius: 6px; border-left: 4px solid #0284c7; margin-bottom: 30px;">
                <tr>
                  <td style="padding: 20px;">
                    <p style="margin: 0 0 12px; color: #0c4a6e; font-size: 14px; font-weight: 600;">📍 Adoption Center Location</p>
                    <p style="margin: 0; color: #0c4a6e; font-size: 14px; line-height: 1.8;">
                      <strong style="font-size: 15px;"><%= @adoption_center_name %></strong><br>
                      <%= @adoption_center_location %>
                    </p>
                  </td>
                </tr>
              </table>

              <p style="margin: 0; color: #6b7280; font-size: 14px; text-align: center;">
                We look forward to helping you bring <%= @pet&.name %> home!
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
