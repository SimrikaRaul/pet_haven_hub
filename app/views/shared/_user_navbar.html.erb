<nav class="navbar">
  <style>
    .navbar {
      background: linear-gradient(135deg, #1F2937 0%, #111827 100%);
      color: #F9FAFB;
      padding: 16px 0;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
      position: sticky;
      top: 0;
      z-index: 1000;
      border-bottom: 2px solid #10B981;
    }

    .navbar-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .navbar-brand {
      font-size: 24px;
      font-weight: 800;
      display: flex;
      align-items: center;
      gap: 10px;
      color: #10B981;
      text-decoration: none;
    }

    .navbar-brand:hover {
      color: #34D399;
    }

    .navbar-menu {
      display: flex;
      gap: 6px;
      align-items: center;
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .navbar-menu a {
      color: #F9FAFB;
      text-decoration: none;
      font-weight: 500;
      font-size: 14px;
      transition: all 0.2s ease;
      padding: 8px 16px;
      border-radius: 20px;
    }

    .navbar-menu a:hover {
      background: rgba(16, 185, 129, 0.2);
      color: #34D399;
    }

    .navbar-auth {
      display: flex;
      gap: 12px;
      align-items: center;
    }

    /* ── Sign-in dropdown (logged out) ── */
    .sign-in-dropdown {
      position: relative;
      display: inline-block;
    }

    .sign-in-button {
      background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);
      color: white;
      padding: 10px 24px;
      font-size: 14px;
      font-weight: 600;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: all 0.3s ease;
      box-shadow: 0 4px 12px rgba(249, 115, 22, 0.3);
    }

    .sign-in-button:hover {
      background: linear-gradient(135deg, #EA580C 0%, #C2410C 100%);
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba(249, 115, 22, 0.4);
    }

    .sign-in-button::after {
      content: '▼';
      font-size: 10px;
      transition: transform 0.3s ease;
    }

    .sign-in-dropdown.active .sign-in-button::after {
      transform: rotate(180deg);
    }

    .sign-in-dropdown .dropdown-menu {
      position: absolute;
      top: calc(100% + 8px);
      right: 0;
      background: white;
      border-radius: 12px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
      min-width: 200px;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-10px);
      transition: all 0.3s ease;
      z-index: 1001;
      overflow: hidden;
    }

    .sign-in-dropdown.active .dropdown-menu {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .sign-in-dropdown .dropdown-item {
      display: block;
      padding: 14px 20px;
      color: #1F2937;
      text-decoration: none;
      font-weight: 500;
      font-size: 14px;
      transition: all 0.2s ease;
      border-bottom: 1px solid #F3F4F6;
    }

    .sign-in-dropdown .dropdown-item:last-child {
      border-bottom: none;
    }

    .sign-in-dropdown .dropdown-item:hover {
      background: linear-gradient(135deg, #FFE4D6 0%, #FED7AA 100%);
      color: #C2410C;
      padding-left: 24px;
    }

    .sign-in-dropdown .dropdown-item.create-account {
      background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);
      color: white;
      font-weight: 600;
    }

    .sign-in-dropdown .dropdown-item.create-account:hover {
      background: linear-gradient(135deg, #EA580C 0%, #C2410C 100%);
      padding-left: 20px;
    }

    /* ── User dropdown (logged in) ── */
    .user-dropdown {
      position: relative;
    }

    .user-dropdown-toggle {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 18px;
      background: rgba(16, 185, 129, 0.15);
      border: 1px solid rgba(16, 185, 129, 0.3);
      border-radius: 24px;
      color: #F9FAFB;
      font-weight: 600;
      font-size: 14px;
      cursor: pointer;
      transition: all 0.3s ease;
      font-family: inherit;
    }

    .user-dropdown-toggle:hover {
      background: rgba(16, 185, 129, 0.25);
      border-color: rgba(16, 185, 129, 0.5);
    }

    .user-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: linear-gradient(135deg, #10B981 0%, #059669 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: 700;
      color: white;
      flex-shrink: 0;
    }

    .user-dropdown-arrow {
      font-size: 10px;
      transition: transform 0.3s ease;
      opacity: 0.7;
    }

    .user-dropdown.active .user-dropdown-arrow {
      transform: rotate(180deg);
    }

    .user-dropdown-menu {
      position: absolute;
      top: calc(100% + 10px);
      right: 0;
      background: linear-gradient(135deg, #1F2937 0%, #111827 100%);
      border: 1px solid rgba(16, 185, 129, 0.2);
      border-radius: 16px;
      min-width: 230px;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-10px);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      z-index: 1001;
      overflow: hidden;
      box-shadow: 0 12px 36px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(16, 185, 129, 0.1);
    }

    .user-dropdown.active .user-dropdown-menu {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .user-dropdown-header {
      padding: 16px 20px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .user-dropdown-header-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, #10B981 0%, #059669 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      font-weight: 700;
      color: white;
      flex-shrink: 0;
    }

    .user-dropdown-header-info {
      display: flex;
      flex-direction: column;
    }

    .user-dropdown-header-name {
      color: #F9FAFB;
      font-weight: 700;
      font-size: 14px;
      line-height: 1.3;
    }

    .user-dropdown-header-email {
      color: #9CA3AF;
      font-size: 12px;
      line-height: 1.3;
    }

    .user-dropdown-divider {
      height: 1px;
      background: rgba(255, 255, 255, 0.08);
      margin: 0;
    }

    .user-dropdown-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 20px;
      color: #D1D5DB;
      text-decoration: none;
      font-weight: 500;
      font-size: 14px;
      transition: all 0.2s ease;
      border: none;
      background: none;
      width: 100%;
      cursor: pointer;
      font-family: inherit;
    }

    .user-dropdown-item:hover {
      background: rgba(16, 185, 129, 0.15);
      color: #34D399;
      padding-left: 24px;
    }

    .user-dropdown-item .dropdown-icon {
      font-size: 16px;
      width: 20px;
      text-align: center;
      flex-shrink: 0;
    }

    .user-dropdown-item.logout-item {
      color: #F87171;
      border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .user-dropdown-item.logout-item:hover {
      background: rgba(239, 68, 68, 0.15);
      color: #FCA5A5;
    }

    .mobile-toggle {
      display: none;
      background: none;
      border: none;
      color: white;
      font-size: 24px;
      cursor: pointer;
    }

    @media (max-width: 768px) {
      .navbar-menu {
        display: none;
        flex-direction: column;
        gap: 0;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: linear-gradient(135deg, #1F2937 0%, #111827 100%);
        width: 100%;
        border-top: 1px solid rgba(16, 185, 129, 0.2);
        padding: 8px 0;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
        z-index: 999;
      }

      .navbar-menu.active {
        display: flex;
      }

      .navbar-menu a {
        padding: 12px 24px;
        border-radius: 0;
      }

      .navbar-menu a:hover {
        background: rgba(16, 185, 129, 0.15);
      }

      .mobile-toggle {
        display: block;
      }

      .navbar-container {
        flex-wrap: wrap;
      }

      .user-dropdown-menu {
        right: -10px;
        min-width: 210px;
      }
    }
  </style>

  <div class="navbar-container">
    <%= link_to root_path, class: 'navbar-brand' do %>
      🐾 Pet Haven Hub
    <% end %>

    <button class="mobile-toggle" onclick="toggleMobileMenu()">☰</button>

    <ul class="navbar-menu" id="navbar-menu">
      <li><%= link_to 'Home', root_path, data: { turbo_action: 'replace' } %></li>
      <li><%= link_to 'Browse Pets', pets_path, data: { turbo_action: 'replace' } %></li>
      <li><%= link_to 'About', about_path %></li>
    </ul>

    <div class="navbar-auth">
      <% if user_signed_in? %>
        <div class="user-dropdown" id="userDropdown">
          <button class="user-dropdown-toggle" onclick="toggleUserDropdown(event)">
            <span class="user-avatar"><%= current_user.full_name[0].upcase %></span>
            <span><%= current_user.full_name %></span>
            <span class="user-dropdown-arrow">▼</span>
          </button>
          <div class="user-dropdown-menu">
            <div class="user-dropdown-header">
              <span class="user-dropdown-header-avatar"><%= current_user.full_name[0].upcase %></span>
              <div class="user-dropdown-header-info">
                <span class="user-dropdown-header-name"><%= current_user.full_name %></span>
                <span class="user-dropdown-header-email"><%= current_user.email %></span>
              </div>
            </div>
            <%= link_to edit_user_registration_path, class: 'user-dropdown-item' do %>
              <span class="dropdown-icon">👤</span> My Profile
            <% end %>
            <%= link_to my_likes_path, class: 'user-dropdown-item' do %>
              <span class="dropdown-icon">❤️</span> My Likes
            <% end %>
            <%= link_to my_wishlist_path, class: 'user-dropdown-item' do %>
              <span class="dropdown-icon">⭐</span> My Wishlist
            <% end %>
            <%= link_to requests_path, class: 'user-dropdown-item' do %>
              <span class="dropdown-icon">📋</span> My Requests
            <% end %>
            <div class="user-dropdown-divider"></div>
            <%= button_to destroy_user_session_path, method: :delete, class: 'user-dropdown-item logout-item', form: { style: 'margin: 0;' } do %>
              <span class="dropdown-icon">🚪</span> Logout
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="sign-in-dropdown" id="signInDropdown">
          <button class="sign-in-button" onclick="toggleSignInDropdown(event)">
            👤 Sign In
          </button>
          <div class="dropdown-menu">
            <%= link_to new_user_session_path, class: 'dropdown-item' do %>
              🔑 Log In
            <% end %>
            <%= link_to new_user_registration_path, class: 'dropdown-item create-account' do %>
              ✨ Create Account
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</nav>

<script>
  function toggleMobileMenu() {
    const menu = document.getElementById('navbar-menu');
    menu.classList.toggle('active');
    // Close user dropdown when opening mobile menu
    const userDd = document.getElementById('userDropdown');
    if (userDd) userDd.classList.remove('active');
  }

  function toggleUserDropdown(e) {
    e.stopPropagation();
    const dropdown = document.getElementById('userDropdown');
    dropdown.classList.toggle('active');
    // Close sign-in dropdown if open
    const signIn = document.getElementById('signInDropdown');
    if (signIn) signIn.classList.remove('active');
  }

  function toggleSignInDropdown(e) {
    e.stopPropagation();
    const dropdown = document.getElementById('signInDropdown');
    dropdown.classList.toggle('active');
  }

  // Close all dropdowns when clicking outside
  document.addEventListener('click', function(event) {
    const userDd = document.getElementById('userDropdown');
    if (userDd && !userDd.contains(event.target)) {
      userDd.classList.remove('active');
    }
    const signInDd = document.getElementById('signInDropdown');
    if (signInDd && !signInDd.contains(event.target)) {
      signInDd.classList.remove('active');
    }
  });
</script>
