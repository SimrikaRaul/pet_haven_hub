<style>
  .edit-user-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
  }
  
  .edit-card {
    background: white;
    border-radius: 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    padding: 2.5rem;
  }
  
  .form-group {
    margin-bottom: 1.75rem;
  }
  
  .form-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 700;
    color: #374151;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .form-input {
    width: 100%;
    padding: 0.875rem 1.25rem;
    border: 2px solid #E5E7EB;
    border-radius: 10px;
    background: #F9FAFB;
    font-size: 1rem;
    outline: none;
    transition: all 0.2s;
    color: #1F2937;
  }
  
  .form-input:focus {
    border-color: #0D5F5C;
    background: white;
    box-shadow: 0 0 0 3px rgba(13, 95, 92, 0.1);
  }
  
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  
  .error-alert {
    background: #FEE2E2;
    border: 2px solid #FCA5A5;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  
  .error-alert h4 {
    color: #991B1B;
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  
  .error-alert ul {
    margin: 0;
    padding-left: 1.5rem;
    color: #B91C1C;
  }
  
  .error-alert li {
    margin-bottom: 0.25rem;
  }
  
  .btn-save {
    padding: 0.875rem 2rem;
    background: linear-gradient(135deg, #0D5F5C 0%, #0A4946 100%);
    color: white;
    border-radius: 12px;
    font-weight: 700;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 12px rgba(13, 95, 92, 0.3);
    transition: all 0.3s;
    font-size: 1rem;
  }
  
  .btn-save:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(13, 95, 92, 0.4);
  }
  
  .btn-cancel {
    padding: 0.875rem 2rem;
    background: white;
    color: #6B7280;
    border: 2px solid #E5E7EB;
    border-radius: 12px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s;
    font-size: 1rem;
    display: inline-block;
  }
  
  .btn-cancel:hover {
    border-color: #9CA3AF;
    color: #374151;
  }
  
  @media (max-width: 768px) {
    .form-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="edit-user-container">
  <!-- Back Button -->
  <div style="margin-bottom: 1.5rem;">
    <%= link_to "← Back to #{@user.name}", admin_user_path(@user), style: 'color: #6B7280; text-decoration: none; font-weight: 600; font-size: 0.9375rem;' %>
  </div>

  <div class="edit-card">
    <div style="margin-bottom: 2rem;">
      <h1 style="font-size: 2rem; font-weight: 800; color: #1F2937; margin-bottom: 0.5rem;">Edit User</h1>
      <p style="color: #6B7280; font-size: 0.9375rem;">Update user information and contact details</p>
    </div>

    <%= form_with(model: [:admin, @user], local: true) do |form| %>
      <% if @user.errors.any? %>
        <div class="error-alert">
          <h4><%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:</h4>
          <ul>
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-group">
        <%= form.label :name, "Full Name", class: 'form-label' %>
        <%= form.text_field :name, class: 'form-input', placeholder: 'Enter full name' %>
      </div>

      <div class="form-group">
        <%= form.label :email, "Email Address", class: 'form-label' %>
        <%= form.email_field :email, class: 'form-input', placeholder: 'user@example.com' %>
      </div>

      <div class="form-group">
        <%= form.label :phone, "Phone Number", class: 'form-label' %>
        <%= form.text_field :phone, class: 'form-input', placeholder: '+1234567890' %>
      </div>

      <div class="form-group">
        <%= form.label :address, "Address", class: 'form-label' %>
        <%= form.text_field :address, class: 'form-input', placeholder: 'Street address' %>
      </div>

      <div class="form-grid">
        <div class="form-group">
          <%= form.label :city, "City", class: 'form-label' %>
          <%= form.text_field :city, class: 'form-input', placeholder: 'City name' %>
        </div>
        <div class="form-group">
          <%= form.label :country, "Country", class: 'form-label' %>
          <%= form.text_field :country, class: 'form-input', placeholder: 'Country name' %>
        </div>
      </div>

      <div style="display: flex; gap: 1rem; margin-top: 2.5rem; padding-top: 2rem; border-top: 2px solid #F3F4F6;">
        <%= form.submit "Save Changes", class: 'btn-save' %>
        <%= link_to 'Cancel', admin_user_path(@user), class: 'btn-cancel' %>
      </div>
    <% end %>
  </div>
</div>
