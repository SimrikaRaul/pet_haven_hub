<div class="min-h-screen flex items-center justify-center px-4 py-12" style="background: #FFFFFF;">
  <div class="max-w-xl w-full">
    <!-- Card Container -->
    <div class="bg-white rounded-3xl shadow-lg p-10 md:p-12 text-center">
      
      <!-- Pet Image Circle -->
      <div class="flex justify-center mb-8">
        <div class="w-40 h-40 rounded-full overflow-hidden border-4 border-orange-300 shadow-lg">
          <%= image_tag "https://images.unsplash.com/photo-1583511655857-d19b40a7a54e?w=400&h=400&fit=crop", 
              alt: "Pet", 
              class: "w-full h-full object-cover",
              onerror: "this.onerror=null; this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22160%22 height=%22160%22%3E%3Crect fill=%22%23FED7AA%22 width=%22160%22 height=%22160%22/%3E%3Ctext x=%2250%25%22 y=%2250%25%22 font-size=%2260%22 text-anchor=%22middle%22 dy=%22.3em%22%3E🐈%3C/text%3E%3C/svg%3E';" %>
        </div>
      </div>
      
      <!-- Header -->
      <div class="mb-6">
        <h2 class="text-4xl font-extrabold mb-4 text-gray-800">
          Create New Password
        </h2>
        <p class="text-gray-600 text-base mb-2 leading-relaxed">
          Please enter your new password below<br>
          to secure your account.
        </p>
        <% if @minimum_password_length %>
          <p class="text-gray-500 text-sm">
            Minimum <%= @minimum_password_length %> characters required
          </p>
        <% end %>
      </div>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
        <%= render "users/shared/error_messages", resource: resource %>
        <%= f.hidden_field :reset_password_token %>

        <!-- New Password Input -->
        <div class="mb-5">
          <div style="position: relative;">
            <%= f.password_field :password, 
                autofocus: true, 
                autocomplete: "new-password", 
                required: true,
                placeholder: 'Enter New Password',
                class: 'w-full px-6 py-4 border-2 border-gray-200 rounded-xl bg-gray-50 text-gray-800 text-center placeholder-gray-400 focus:border-orange-400 focus:bg-white focus:outline-none transition-all duration-200 text-lg',
                style: 'padding-right: 3rem;' %>
            <button type="button" class="_eye-toggle" onclick="togglePwVis(this)" style="position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:1.2rem;color:#6B7280;padding:4px;line-height:1;" title="Show password">👁️</button>
          </div>
          <div id="pw-strength" style="margin-top:0.5rem;"></div>
        </div>

        <!-- Confirm Password Input -->
        <div class="mb-6">
          <div style="position: relative;">
            <%= f.password_field :password_confirmation, 
                autocomplete: "new-password", 
                required: true,
                placeholder: 'Confirm New Password',
                class: 'w-full px-6 py-4 border-2 border-gray-200 rounded-xl bg-gray-50 text-gray-800 text-center placeholder-gray-400 focus:border-orange-400 focus:bg-white focus:outline-none transition-all duration-200 text-lg',
                style: 'padding-right: 3rem;' %>
            <button type="button" class="_eye-toggle" onclick="togglePwVis(this)" style="position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:1.2rem;color:#6B7280;padding:4px;line-height:1;" title="Show password">👁️</button>
          </div>
        </div>

        <!-- Submit Button -->
        <div class="mb-4">
          <%= f.submit "Change Password", 
              class: 'w-full md:w-64 mx-auto block py-4 px-8 rounded-full font-bold text-white text-lg shadow-lg hover:shadow-xl transform hover:scale-105 transition-all duration-200 cursor-pointer',
              style: 'background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);' %>
        </div>
      <% end %>

    </div>

    <!-- Bottom Links -->
    <div class="text-center mt-8 space-y-3">
      <%= link_to new_session_path(resource_name), class: 'block text-gray-600 hover:text-orange-600 font-medium text-sm transition-colors duration-200' do %>
        <span>← Back to Login</span>
      <% end %>
      
      <% if devise_mapping.registerable? %>
        <div class="text-gray-600 text-sm">
          Don't have an account?
          <%= link_to "Sign up", new_registration_path(resource_name), class: 'text-orange-600 hover:text-orange-700 font-semibold ml-1' %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
function togglePwVis(btn) {
  var inp = btn.parentElement.querySelector('input');
  if (inp.type === 'password') { inp.type = 'text'; btn.textContent = '🙈'; btn.title = 'Hide password'; }
  else { inp.type = 'password'; btn.textContent = '👁️'; btn.title = 'Show password'; }
}
function showPwStrength(val) {
  var el = document.getElementById('pw-strength');
  if (!el) return;
  if (!val) { el.innerHTML = ''; return; }
  var score = 0;
  if (val.length >= 8) score++;
  if (/[A-Z]/.test(val)) score++;
  if (/[a-z]/.test(val)) score++;
  if (/\d/.test(val)) score++;
  if (/[^A-Za-z0-9]/.test(val)) score++;
  var labels = ['Very Weak','Weak','Fair','Strong','Very Strong'];
  var colors = ['#EF4444','#F97316','#F59E0B','#10B981','#059669'];
  var pct = [20,40,60,80,100];
  var i = Math.max(0, score - 1);
  el.innerHTML = '<div style="display:flex;align-items:center;gap:0.5rem;"><div style="flex:1;height:6px;background:#E5E7EB;border-radius:3px;overflow:hidden;"><div style="width:'+pct[i]+'%;height:100%;background:'+colors[i]+';border-radius:3px;transition:all 0.3s;"></div></div><span style="font-size:0.75rem;font-weight:700;color:'+colors[i]+';white-space:nowrap;">'+labels[i]+'</span></div>';
}
(function() {
  var pEl  = document.getElementById('user_password');
  var cpEl = document.getElementById('user_password_confirmation');
  if (!pEl || !cpEl) return;
  var form = pEl.closest('form');
  form.setAttribute('novalidate', '');
  var minLen = 8;
  function ferr(el, msg) {
    fclr(el);
    el.style.borderColor = '#EF4444'; el.style.boxShadow = '0 0 0 3px rgba(239,68,68,0.12)';
    var s = document.createElement('span');
    s.className = '_fve';
    s.style.cssText = 'display:block;color:#DC2626;font-size:0.8rem;font-weight:600;margin-top:0.4rem;padding-left:0.5rem;';
    s.textContent = '\u26a0 ' + msg;
    el.parentNode.appendChild(s);
  }
  function fclr(el) {
    var xs = el.parentNode.querySelectorAll('._fve'); xs.forEach(function(x){x.remove();});
    el.style.borderColor = ''; el.style.boxShadow = '';
  }
  function fok(el) { fclr(el); el.style.borderColor = '#10B981'; el.style.boxShadow = '0 0 0 3px rgba(16,185,129,0.1)'; }
  function vPw() {
    var v = pEl.value;
    showPwStrength(v);
    if (!v) { ferr(pEl, 'New password is required'); return false; }
    if (v.length < minLen) { ferr(pEl, 'Password must be at least ' + minLen + ' characters'); return false; }
    if (!/[A-Z]/.test(v)) { ferr(pEl, 'Must include at least one uppercase letter'); return false; }
    if (!/[a-z]/.test(v)) { ferr(pEl, 'Must include at least one lowercase letter'); return false; }
    if (!/\d/.test(v)) { ferr(pEl, 'Must include at least one number'); return false; }
    fok(pEl); if (cpEl.value) vCpw(); return true;
  }
  function vCpw() {
    var v = cpEl.value;
    if (!v) { ferr(cpEl, 'Please confirm your password'); return false; }
    if (v !== pEl.value) { ferr(cpEl, 'Passwords do not match'); return false; }
    fok(cpEl); return true;
  }
  [[pEl,vPw],[cpEl,vCpw]].forEach(function(pair) {
    pair[0].addEventListener('blur', pair[1]);
    pair[0].addEventListener('input', function() { if (pair[0].parentNode.querySelector('._fve')) pair[1](); });
  });
  pEl.addEventListener('input', function() { showPwStrength(pEl.value); });
  form.addEventListener('submit', function(ev) {
    var ok = vPw() & vCpw();
    if (!ok) { ev.preventDefault(); var f = form.querySelector('._fve'); if (f) { var inp = f.parentNode.querySelector('input'); if (inp) inp.focus(); } }
  });
})();
</script>


