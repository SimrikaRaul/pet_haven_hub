<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; background-color: #f3f4f6;">
  <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f3f4f6;">
    <tr>
      <td style="padding: 20px; text-align: center;">
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
          <tr>
            <td style="background: linear-gradient(135deg, #4F46E5 0%, #6366f1 100%); padding: 40px 20px; text-align: center; border-radius: 8px 8px 0 0;">
              <h1 style="margin: 0; color: #ffffff; font-size: 28px; font-weight: 700;">📈 Weekly Report</h1>
              <p style="margin: 8px 0 0; color: rgba(255,255,255,0.9); font-size: 14px;">This Week's Statistics</p>
            </td>
          </tr>
          <tr>
            <td style="padding: 40px 30px;">
              <h2 style="margin: 0 0 20px; color: #1f2937; font-size: 24px; font-weight: 600;">Weekly Statistics</h2>
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 30px;">
                <tr>
                  <td style="padding: 16px; background: #f0f4ff; border-radius: 6px; border-left: 4px solid #4F46E5; margin-bottom: 12px;">
                    <p style="margin: 0 0 4px; color: #4F46E5; font-size: 12px; font-weight: 600; text-transform: uppercase;">Requests Submitted</p>
                    <p style="margin: 0; color: #1f2937; font-size: 24px; font-weight: 700;"><%= @stats[:requests_submitted] %></p>
                  </td>
                </tr>
                <tr>
                  <td style="padding: 16px; background: #f0fdf4; border-radius: 6px; border-left: 4px solid #059669; margin-bottom: 12px;">
                    <p style="margin: 0 0 4px; color: #059669; font-size: 12px; font-weight: 600; text-transform: uppercase;">Requests Approved</p>
                    <p style="margin: 0; color: #1f2937; font-size: 24px; font-weight: 700;"><%= @stats[:requests_approved] %></p>
                  </td>
                </tr>
                <tr>
                  <td style="padding: 16px; background: #fee2e2; border-radius: 6px; border-left: 4px solid #dc2626; margin-bottom: 12px;">
                    <p style="margin: 0 0 4px; color: #dc2626; font-size: 12px; font-weight: 600; text-transform: uppercase;">Requests Rejected</p>
                    <p style="margin: 0; color: #1f2937; font-size: 24px; font-weight: 700;"><%= @stats[:requests_rejected] %></p>
                  </td>
                </tr>
                <tr>
                  <td style="padding: 16px; background: #fef3c7; border-radius: 6px; border-left: 4px solid #d97706;">
                    <p style="margin: 0 0 4px; color: #d97706; font-size: 12px; font-weight: 600; text-transform: uppercase;">New Pets Added</p>
                    <p style="margin: 0; color: #1f2937; font-size: 24px; font-weight: 700;"><%= @stats[:new_pets] %></p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="background-color: #f9fafb; padding: 30px; border-radius: 0 0 8px 8px; border-top: 1px solid #e5e7eb;">
              <p style="margin: 0 0 12px; color: #6b7280; font-size: 14px; line-height: 1.6;">
                <strong style="color: #1f2937;">Pet Haven Hub Admin</strong><br>
                Panauti, Kathmandu, Nepal
              </p>
              <p style="margin: 0; color: #6b7280; font-size: 12px;">
                © <%= Time.current.year %> Pet Haven Hub. All rights reserved.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
