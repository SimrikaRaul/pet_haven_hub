<% if page.current? %>
  <li>
    <%= content_tag :a, page, data: { remote: remote }, rel: page.rel, style: 'display: inline-flex; align-items: center; justify-content: center; padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.95rem; font-weight: 700; background: linear-gradient(135deg, #0D5F5C 0%, #0A4946 100%); color: white; text-decoration: none; cursor: default;' %>
  </li>
<% else %>
  <li>
    <%= link_to page, url, remote: remote, rel: page.rel, style: 'display: inline-flex; align-items: center; justify-content: center; padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.95rem; font-weight: 600; background: white; color: #4B5563; text-decoration: none; border: 2px solid #E5E7EB; transition: all 0.3s ease;' %>
  </li>
<% end %>
