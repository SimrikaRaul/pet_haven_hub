<style>
  :root {
    --green-primary: #10B981;
    --green-dark: #059669;
    --green-light: #34D399;
    --green-soft: #D1FAE5;
    --green-gradient: linear-gradient(135deg, #10B981 0%, #34D399 100%);
    --warm-peach: #FFE4D6;
    --warm-cream: #FFF5EB;
    --warm-orange: #F97316;
  }

  .page-container {
    width: 100%;
    margin: 0;
    padding: 0;
    background: linear-gradient(180deg, var(--warm-cream) 0%, #FAFAFA 100%);
    min-height: 100vh;
    position: relative;
  }

  .page-container::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 300px;
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.08) 0%, rgba(52, 211, 153, 0.05) 100%);
    pointer-events: none;
  }

  .content-wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: 40px 24px;
  }

  .page-header {
    margin-bottom: 36px;
    text-align: center;
    position: relative;
  }

  .page-header::after {
    content: '';
    display: block;
    width: 80px;
    height: 4px;
    background: var(--green-gradient);
    margin: 20px auto 0;
    border-radius: 2px;
  }

  .page-title {
    font-size: 2.75rem;
    font-weight: 800;
    background: linear-gradient(135deg, #1F2937 0%, var(--green-primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 12px;
    letter-spacing: -0.03em;
  }

  .page-subtitle {
    color: #64748B;
    font-size: 1.125rem;
    font-weight: 400;
    margin-bottom: 0;
  }

  .filter-container {
    background: white;
    padding: 8px;
    border-radius: 16px;
    display: inline-flex;
    gap: 6px;
    box-shadow: 0 4px 20px rgba(16, 185, 129, 0.1);
    border: 1px solid rgba(16, 185, 129, 0.1);
  }

  .filter-tab {
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    background: transparent;
    color: #6B7280;
    border: none;
    font-weight: 600;
    letter-spacing: 0.3px;
    font-size: 0.9rem;
    padding: 12px 24px;
    border-radius: 12px;
    position: relative;
    overflow: hidden;
  }

  .filter-tab::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--green-gradient);
    opacity: 0;
    transition: opacity 0.3s ease;
    border-radius: 12px;
  }

  .filter-tab span {
    position: relative;
    z-index: 1;
  }

  .filter-tab.active {
    color: white;
    box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
  }

  .filter-tab.active::before {
    opacity: 1;
  }

  .filter-tab:not(.active):hover {
    background: var(--green-soft);
    color: var(--green-primary);
    transform: translateY(-1px);
  }

  .requests-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 30px;
    width: 100%;
  }

  .request-card {
    background: white;
    border-radius: 24px;
    border: 1px solid rgba(16, 185, 129, 0.08);
    box-shadow: 0 4px 24px rgba(16, 185, 129, 0.06);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    position: relative;
    height: 100%;
  }

  .request-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--green-gradient);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .request-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(16, 185, 129, 0.15);
    border-color: rgba(16, 185, 129, 0.15);
  }

  .request-card:hover::before {
    opacity: 1;
  }

  .card-image-wrapper {
    position: relative;
    padding: 24px 24px 0;
  }

  .request-card-image {
    width: 100%;
    max-width: 180px;
    height: 180px;
    object-fit: cover;
    border-radius: 20px;
    margin: 0 auto;
    display: block;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .request-card:hover .request-card-image {
    transform: scale(1.03);
    box-shadow: 0 12px 32px rgba(16, 185, 129, 0.2);
  }

  .request-card-image-placeholder {
    background: var(--green-gradient);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
  }

  .card-content {
    padding: 24px 28px 28px;
  }

  .pet-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1F2937;
    text-align: center;
    margin-bottom: 12px;
    transition: color 0.3s ease;
  }

  .request-card:hover .pet-name {
    color: var(--green-primary);
  }

  .badge-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .request-type-badge {
    background: var(--green-gradient);
    color: white;
    padding: 6px 16px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 1px;
    border-radius: 20px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    box-shadow: 0 2px 8px rgba(16, 185, 129, 0.25);
  }

  .status-badge {
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.5px;
    padding: 6px 14px;
    border-radius: 20px;
    display: inline-block;
    text-transform: uppercase;
  }

  .status-pending {
    background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
    color: #92400E;
    border: 1px solid #F59E0B;
  }

  .status-approved {
    background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
    color: #065F46;
    border: 1px solid #10B981;
  }

  .status-rejected {
    background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
    color: #991B1B;
    border: 1px solid #EF4444;
  }

  .status-scheduled {
    background: linear-gradient(135deg, #EDE9FE 0%, #DDD6FE 100%);
    color: #5B21B6;
    border: 1px solid #8B5CF6;
  }

  .status-completed {
    background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
    color: #1E40AF;
    border: 1px solid #3B82F6;
  }

  .info-section {
    background: linear-gradient(135deg, #FAFAFA 0%, #F5F5F5 100%);
    border-radius: 16px;
    padding: 18px 20px;
    margin: 16px 0;
    border: 1px solid #E5E7EB;
  }

  .info-row {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.9rem;
    margin-bottom: 10px;
    line-height: 1.5;
  }

  .info-row:last-child {
    margin-bottom: 0;
  }

  .info-icon {
    width: 32px;
    height: 32px;
    background: white;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    box-shadow: 0 2px 8px rgba(16, 185, 129, 0.08);
    flex-shrink: 0;
  }

  .info-label {
    color: #6B7280;
    font-weight: 500;
    min-width: 80px;
    flex-shrink: 0;
  }

  .info-value {
    color: #1F2937;
    font-weight: 600;
  }

  .view-details-btn {
    background: var(--green-gradient);
    color: white;
    padding: 14px 24px;
    border-radius: 14px;
    font-weight: 600;
    font-size: 0.95rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    width: 100%;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(16, 185, 129, 0.25);
    position: relative;
    overflow: hidden;
  }

  .view-details-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.5s ease;
  }

  .view-details-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(16, 185, 129, 0.35);
  }

  .view-details-btn:hover::before {
    left: 100%;
  }

  .status-text {
    text-align: center;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px dashed #E5E7EB;
  }

  .awaiting-text {
    color: #6B7280;
    font-size: 0.9rem;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 500;
    padding: 8px 16px;
    background: #F9FAFB;
    border-radius: 20px;
  }

  .awaiting-text.approved { color: #059669; background: #ECFDF5; }
  .awaiting-text.completed { color: #2563EB; background: #EFF6FF; }
  .awaiting-text.rejected { color: #DC2626; background: #FEF2F2; }

  .alert-box {
    border-radius: 12px;
    padding: 14px 16px;
    margin-bottom: 16px;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .alert-success {
    background: linear-gradient(135deg, #ECFDF5 0%, #D1FAE5 100%);
    border: 1px solid #10B981;
    color: #065F46;
  }

  .alert-danger {
    background: linear-gradient(135deg, #FEF2F2 0%, #FEE2E2 100%);
    border: 1px solid #EF4444;
    color: #991B1B;
  }

  .alert-info {
    background: linear-gradient(135deg, #F9FAFB 0%, #F3F4F6 100%);
    border: 1px solid #D1D5DB;
    color: #4B5563;
  }

  .browse-pets-btn {
    background: var(--green-gradient);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 6px 20px rgba(16, 185, 129, 0.3);
  }

  .browse-pets-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(16, 185, 129, 0.4);
  }

  .empty-state {
    text-align: center;
    padding: 60px 40px;
    background: linear-gradient(145deg, #ffffff 0%, #f0fdf4 50%, #ecfdf5 100%);
    border-radius: 32px;
    box-shadow: 0 8px 32px rgba(16, 185, 129, 0.08), 0 1px 3px rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(16, 185, 129, 0.12);
    position: relative;
    overflow: hidden;
  }

  .empty-state::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, rgba(16, 185, 129, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .empty-state::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: -30%;
    width: 80%;
    height: 80%;
    background: radial-gradient(circle, rgba(52, 211, 153, 0.05) 0%, transparent 60%);
    pointer-events: none;
  }

  .empty-icon-group {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: 16px;
    margin-bottom: 32px;
    position: relative;
    z-index: 1;
  }

  .empty-icon {
    font-size: 3rem;
    animation: float 3s ease-in-out infinite;
    filter: drop-shadow(0 8px 16px rgba(16, 185, 129, 0.15));
  }

  .empty-icon:nth-child(1) {
    animation-delay: 0s;
  }

  .empty-icon:nth-child(2) {
    font-size: 4.5rem;
    animation-delay: 0.3s;
  }

  .empty-icon:nth-child(3) {
    animation-delay: 0.6s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    25% { transform: translateY(-8px) rotate(-3deg); }
    75% { transform: translateY(-4px) rotate(3deg); }
  }

  .empty-title {
    font-size: 1.875rem;
    font-weight: 700;
    background: linear-gradient(135deg, #1F2937 0%, var(--green-primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 16px;
    position: relative;
    z-index: 1;
  }

  .empty-description {
    font-size: 1.1rem;
    color: #64748B;
    margin-bottom: 36px;
    max-width: 420px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
    position: relative;
    z-index: 1;
  }

  .empty-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    position: relative;
    z-index: 1;
  }

  .browse-pets-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 32px;
    background: var(--green-gradient);
    color: white;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 14px;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 8px 24px rgba(16, 185, 129, 0.35);
    position: relative;
    overflow: hidden;
  }

  .browse-pets-btn-primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.25), transparent);
    transition: left 0.6s ease;
  }

  .browse-pets-btn-primary:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 16px 40px rgba(16, 185, 129, 0.4);
  }

  .browse-pets-btn-primary:hover::before {
    left: 100%;
  }

  .empty-hint {
    font-size: 0.9rem;
    color: #94A3B8;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  @media (max-width: 1024px) {
    .content-wrapper {
      padding: 40px 24px;
    }

    .requests-grid {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
    }
  }

  @media (max-width: 768px) {
    .content-wrapper {
      padding: 30px 16px;
    }

    .page-title {
      font-size: 2rem;
    }

    .page-subtitle {
      font-size: 1rem;
    }

    .filter-container {
      flex-direction: column;
      width: 100%;
      gap: 6px;
    }

    .filter-tab {
      width: 100%;
      text-align: center;
    }

    .requests-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .request-card-image {
      max-width: 150px;
      height: 150px;
    }

    .card-content {
      padding: 20px;
    }

    .info-label {
      min-width: 70px;
    }
  }
</style>

<div class="page-container">
  <div class="content-wrapper">
    <!-- Page Header -->
    <div class="page-header">
      <h1 class="page-title">My Adoption Requests</h1>
      <p class="page-subtitle">Track and manage your adoption applications</p>
    </div>

  <% if @requests.any? %>
    <!-- Filter Tabs -->
    <div style="text-align: center; margin-bottom: 32px;">
      <div class="filter-container">
        <button class="filter-tab active" data-filter="all">
          <span>All Requests</span>
        </button>
        <button class="filter-tab" data-filter="in-progress">
          <span>In Progress</span>
        </button>
        <button class="filter-tab" data-filter="completed">
          <span>Completed</span>
        </button>
      </div>
    </div>

    <!-- Request Cards Grid -->
    <div class="requests-grid" id="requests-container">
      <% @requests.each do |req| %>
        <div data-status="<%= req.status %>" style="transition: opacity 0.3s ease;">
          <div class="request-card">
          
            <!-- Pet Image -->
            <div class="card-image-wrapper">
              <% if req.pet.image.attached? %>
                <%= image_tag req.pet.image, alt: req.pet.name, class: 'request-card-image' %>
              <% else %>
                <div class="request-card-image request-card-image-placeholder">
                  <%= req.pet.pet_type == 'dog' ? '🐕' : req.pet.pet_type == 'cat' ? '🐈' : '🐾' %>
                </div>
              <% end %>
            </div>

            <div class="card-content">
              <!-- Pet Name -->
              <h3 class="pet-name"><%= req.pet.name %></h3>

              <!-- Badges Row -->
              <div class="badge-row">
                <span class="request-type-badge">
                  <%= req.request_type == 'adopt' ? '🏠' : '💝' %> <%= req.request_type.upcase %>
                </span>
                <span class="status-badge <%= case req.status
                    when 'open' then 'status-pending'
                    when 'approved' then 'status-approved'
                    when 'rejected' then 'status-rejected'
                    when 'scheduled' then 'status-scheduled'
                    when 'completed' then 'status-completed'
                    else 'status-pending'
                    end %>">
                  <%= req.status == 'open' ? 'PENDING' : req.status.upcase %>
                </span>
              </div>

              <!-- Pet Details -->
              <div class="info-section">
                <div class="info-row">
                  <span class="info-icon">🐾</span>
                  <span class="info-label">Type</span>
                  <span class="info-value"><%= req.pet.pet_type.titleize %></span>
                </div>
                <div class="info-row">
                  <span class="info-icon">🎯</span>
                  <span class="info-label">Breed</span>
                  <span class="info-value"><%= req.pet.breed %></span>
                </div>
                <div class="info-row">
                  <span class="info-icon">📅</span>
                  <span class="info-label">Requested</span>
                  <span class="info-value"><%= req.created_at.strftime('%b %d, %Y') %></span>
                </div>

              <!-- Rejection Reason -->
              <% if req.rejected? && req.rejection_reason.present? %>
                <div class="alert-box alert-danger">
                  <span>✗</span>
                  <span><strong>Reason:</strong> <%= req.rejection_reason %></span>
                </div>
              <% end %>

              <!-- User Notes -->
              <% if req.notes.present? %>
                <div class="alert-box alert-info">
                  <span>📝</span>
                  <span><strong>Notes:</strong> <%= req.notes.truncate(100) %></span>
                </div>
              <% end %>

              <!-- Action Button -->
              <%= link_to pet_path(req.pet), class: 'view-details-btn' do %>
                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                </svg>
                View Pet Details
              <% end %>

              <!-- Status Text -->
              <div class="status-text">
                <% if req.open? %>
                  <span class="awaiting-text">
                    ⏳ Awaiting Review
                  </span>
                <% elsif req.approved? %>
                  <span class="awaiting-text approved">
                    ✓ Request Approved
                  </span>
                <% elsif req.completed? %>
                  <span class="awaiting-text completed">
                    ✓ Adoption Completed
                  </span>
                <% elsif req.rejected? %>
                  <span class="awaiting-text rejected">
                    ✗ Request Rejected
                  </span>
                <% end %>
              </div>
          </div>
        </div>
      <% end %>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const filterTabs = document.querySelectorAll('.filter-tab');
        const requestCards = document.querySelectorAll('#requests-container > div');

        filterTabs.forEach(tab => {
          tab.addEventListener('click', function() {
            const filter = this.getAttribute('data-filter');
            
            // Update active tab
            filterTabs.forEach(t => t.classList.remove('active'));
            this.classList.add('active');

            // Filter cards
            requestCards.forEach(card => {
              const cardStatus = card.getAttribute('data-status');
              let shouldShow = false;

              if (filter === 'all') {
                shouldShow = true;
              } else if (filter === 'in-progress') {
                shouldShow = ['open', 'approved', 'scheduled', 'rejected'].includes(cardStatus);
              } else if (filter === 'completed') {
                shouldShow = cardStatus === 'completed';
              }

              if (shouldShow) {
                card.style.display = 'block';
                setTimeout(() => card.style.opacity = '1', 10);
              } else {
                card.style.opacity = '0';
                setTimeout(() => card.style.display = 'none', 300);
              }
            });
          });
        });
      });
    </script>

  <% else %>
    <!-- Beautiful Empty State Section -->
    <div class="empty-state">
      <div class="empty-icon-group">
        <span class="empty-icon">🐕</span>
        <span class="empty-icon">�</span>
        <span class="empty-icon">🐈</span>
      </div>
      
      <h2 class="empty-title">Your Journey Begins Here</h2>
      <p class="empty-description">
        You haven't made any adoption requests yet. Discover your perfect furry companion and start your journey to bringing home a new best friend!
      </p>
      
      <div class="empty-actions">
        <%= link_to pets_path, class: 'browse-pets-btn-primary' do %>
          <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <span>Find Your Perfect Pet</span>
        <% end %>
        
        <p class="empty-hint">
          <span>✨</span>
          <span>Over <%= Pet.available.count %> pets waiting for their forever home</span>
        </p>
      </div>
    </div>
  <% end %>
</div>
</div>
