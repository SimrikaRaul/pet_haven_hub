<style>
  :root {
    --green-primary: #10B981;
    --green-dark: #059669;
    --green-light: #34D399;
    --green-soft: #D1FAE5;
    --green-gradient: linear-gradient(135deg, #10B981 0%, #34D399 100%);
    --warm-peach: #FFE4D6;
    --warm-cream: #FFF5EB;
    --warm-orange: #F97316;
  }

  .page-container {
    width: 100%;
    margin: 0;
    padding: 0;
    background: linear-gradient(180deg, var(--warm-cream) 0%, #FAFAFA 100%);
    min-height: 100vh;
    position: relative;
  }

  .page-container::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 300px;
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.08) 0%, rgba(52, 211, 153, 0.05) 100%);
    pointer-events: none;
  }

  .content-wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 24px;
  }

  .page-header {
    margin-bottom: 36px;
    text-align: center;
    position: relative;
  }

  .page-header::after {
    content: '';
    display: block;
    width: 80px;
    height: 4px;
    background: var(--green-gradient);
    margin: 20px auto 0;
    border-radius: 2px;
  }

  .page-title {
    font-size: 2.75rem;
    font-weight: 800;
    background: linear-gradient(135deg, #1F2937 0%, var(--green-primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 12px;
    letter-spacing: -0.03em;
  }

  .page-subtitle {
    color: #64748B;
    font-size: 1.125rem;
    font-weight: 400;
    margin-bottom: 0;
  }

  .filter-container {
    background: white;
    padding: 8px;
    border-radius: 16px;
    display: inline-flex;
    gap: 6px;
    box-shadow: 0 4px 20px rgba(16, 185, 129, 0.1);
    border: 1px solid rgba(16, 185, 129, 0.1);
  }

  .filter-tab {
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    background: transparent;
    color: #6B7280;
    border: none;
    font-weight: 600;
    letter-spacing: 0.3px;
    font-size: 0.9rem;
    padding: 12px 24px;
    border-radius: 12px;
    position: relative;
    overflow: hidden;
  }

  .filter-tab::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--green-gradient);
    opacity: 0;
    transition: opacity 0.3s ease;
    border-radius: 12px;
  }

  .filter-tab span {
    position: relative;
    z-index: 1;
  }

  .filter-tab.active {
    color: white;
    box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
  }

  .filter-tab.active::before {
    opacity: 1;
  }

  .filter-tab:not(.active):hover {
    background: var(--green-soft);
    color: var(--green-primary);
    transform: translateY(-1px);
  }

  /* GRID LAYOUT - 3 cards side by side */
  .requests-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    width: 100%;
    margin: 0;
    padding: 0;
  }

  .request-card {
    background: white;
    border-radius: 24px;
    border: none;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
  }

  .request-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.12);
  }

  /* LARGE IMAGE SECTION */
  .card-image-wrapper {
    position: relative;
    width: 100%;
    height: 240px;
    overflow: hidden;
    background: linear-gradient(135deg, var(--warm-peach) 0%, var(--warm-cream) 100%);
    flex-shrink: 0;
  }

  .request-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .request-card:hover .request-card-image {
    transform: scale(1.08);
  }

  .request-card-image-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5rem;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #10B981 0%, #34D399 100%);
  }

  /* CONTENT SECTION */
  .card-content {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex-grow: 1;
  }

  .pet-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1F2937;
    margin: 0;
  }

  /* PET INFO LINE - Type, Breed, Age */
  .pet-info-line {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.95rem;
    color: #6B7280;
  }

  .pet-type-badge {
    background: #B8E6DB;
    color: #0D6B5B;
    padding: 6px 16px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    white-space: nowrap;
  }

  .pet-info-text {
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .pet-info-text .separator {
    color: #D1D5DB;
  }

  /* HIDDEN SECTIONS */
  .info-section {
    display: none;
  }

  .alert-box {
    display: none;
  }

  .badge-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
    margin-top: 8px;
  }

  .request-type-badge {
    background: var(--green-gradient);
    color: white;
    padding: 6px 14px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    border-radius: 20px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    box-shadow: 0 2px 8px rgba(16, 185, 129, 0.2);
    white-space: nowrap;
  }

  .status-badge {
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.5px;
    padding: 6px 14px;
    border-radius: 20px;
    display: inline-block;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .status-pending {
    background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
    color: #92400E;
    border: 1px solid #F59E0B;
  }

  .status-approved {
    background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
    color: #065F46;
    border: 1px solid #10B981;
  }

  .status-rejected {
    background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
    color: #991B1B;
    border: 1px solid #EF4444;
  }

  .status-scheduled {
    background: linear-gradient(135deg, #EDE9FE 0%, #DDD6FE 100%);
    color: #5B21B6;
    border: 1px solid #8B5CF6;
  }

  .status-completed {
    background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
    color: #1E40AF;
    border: 1px solid #3B82F6;
  }

  .status-text {
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid #E5E7EB;
    text-align: center;
  }

  .awaiting-text {
    color: #6B7280;
    font-size: 0.8rem;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-weight: 500;
    padding: 6px 12px;
    background: #F9FAFB;
    border-radius: 16px;
  }

  .awaiting-text.approved { color: #059669; background: #ECFDF5; }
  .awaiting-text.completed { color: #2563EB; background: #EFF6FF; }
  .awaiting-text.rejected { color: #DC2626; background: #FEF2F2; }

  /* ACTION BUTTON */
  .view-details-btn {
    background: var(--green-gradient);
    color: white;
    padding: 12px 24px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.95rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.25);
    position: relative;
    overflow: hidden;
    width: 100%;
    margin-top: auto;
  }

  .view-details-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.5s ease;
  }

  .view-details-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(16, 185, 129, 0.35);
  }

  .view-details-btn:hover::before {
    left: 100%;
  }

  /* EMPTY STATE */
  .empty-state {
    text-align: center;
    padding: 60px 40px;
    background: linear-gradient(145deg, #ffffff 0%, #f0fdf4 50%, #ecfdf5 100%);
    border-radius: 32px;
    box-shadow: 0 8px 32px rgba(16, 185, 129, 0.08), 0 1px 3px rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(16, 185, 129, 0.12);
    position: relative;
    overflow: hidden;
  }

  .empty-state::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, rgba(16, 185, 129, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .empty-state::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: -30%;
    width: 80%;
    height: 80%;
    background: radial-gradient(circle, rgba(52, 211, 153, 0.05) 0%, transparent 60%);
    pointer-events: none;
  }

  .empty-icon-group {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: 16px;
    margin-bottom: 32px;
    position: relative;
    z-index: 1;
  }

  .empty-icon {
    font-size: 3rem;
    animation: float 3s ease-in-out infinite;
    filter: drop-shadow(0 8px 16px rgba(16, 185, 129, 0.15));
  }

  .empty-icon:nth-child(1) {
    animation-delay: 0s;
  }

  .empty-icon:nth-child(2) {
    font-size: 4.5rem;
    animation-delay: 0.3s;
  }

  .empty-icon:nth-child(3) {
    animation-delay: 0.6s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    25% { transform: translateY(-8px) rotate(-3deg); }
    75% { transform: translateY(-4px) rotate(3deg); }
  }

  .empty-title {
    font-size: 1.875rem;
    font-weight: 700;
    background: linear-gradient(135deg, #1F2937 0%, var(--green-primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 16px;
    position: relative;
    z-index: 1;
  }

  .empty-description {
    font-size: 1.1rem;
    color: #64748B;
    margin-bottom: 36px;
    max-width: 420px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
    position: relative;
    z-index: 1;
  }

  .empty-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    position: relative;
    z-index: 1;
  }

  .browse-pets-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 32px;
    background: var(--green-gradient);
    color: white;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 14px;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 8px 24px rgba(16, 185, 129, 0.35);
    position: relative;
    overflow: hidden;
  }

  .browse-pets-btn-primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.25), transparent);
    transition: left 0.6s ease;
  }

  .browse-pets-btn-primary:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 16px 40px rgba(16, 185, 129, 0.4);
  }

  .browse-pets-btn-primary:hover::before {
    left: 100%;
  }

  .empty-hint {
    font-size: 0.9rem;
    color: #94A3B8;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .requests-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  @media (max-width: 768px) {
    .content-wrapper {
      padding: 24px 16px;
    }

    .page-title {
      font-size: 1.75rem;
    }

    .page-subtitle {
      font-size: 0.95rem;
    }

    .filter-container {
      flex-direction: column;
      width: 100%;
      gap: 6px;
    }

    .filter-tab {
      width: 100%;
      text-align: center;
      padding: 10px 16px;
      font-size: 0.85rem;
    }

    .requests-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .card-image-wrapper {
      height: 180px;
    }

    .card-content {
      padding: 18px;
      gap: 12px;
    }

    .pet-name {
      font-size: 1.25rem;
    }

    .pet-info-line {
      font-size: 0.9rem;
    }

    .view-details-btn {
      padding: 10px 16px;
      font-size: 0.85rem;
    }
  }
</style>

<div class="page-container">
  <div class="content-wrapper">
    <!-- Page Header -->
    <div class="page-header">
      <h1 class="page-title">My Adoption Requests</h1>
      <p class="page-subtitle">Track and manage your adoption applications</p>
    </div>

  <% if @requests.any? %>
    <!-- Filter Tabs -->
    <div style="text-align: center; margin-bottom: 32px;">
      <div class="filter-container">
        <button class="filter-tab active" data-filter="all">
          <span>All Requests</span>
        </button>
        <button class="filter-tab" data-filter="in-progress">
          <span>In Progress</span>
        </button>
        <button class="filter-tab" data-filter="completed">
          <span>Completed</span>
        </button>
      </div>
    </div>

    <!-- Request Cards Grid -->
    <div class="requests-grid" id="requests-container">
      <% @requests.slice(0, 3).each do |req| %>
        <div data-status="<%= req.status %>" style="transition: opacity 0.3s ease;">
          <div class="request-card">

            <!-- Pet Image -->
            <div class="card-image-wrapper">
              <% if req.pet.image.attached? %>
                <%= image_tag req.pet.image, alt: req.pet.name, class: 'request-card-image' %>
              <% else %>
                <div class="request-card-image request-card-image-placeholder">
                  <%= req.pet.pet_type == 'dog' ? '🐕' : req.pet.pet_type == 'cat' ? '🐈' : '🐾' %>
                </div>
              <% end %>
            </div>

            <div class="card-content">
              <!-- Pet Name -->
              <h3 class="pet-name"><%= req.pet.name %></h3>

              <!-- Pet Info Line: Type Badge + Breed + Age -->
              <div class="pet-info-line">
                <span class="pet-type-badge"><%= req.pet.pet_type.titleize %></span>
                <div class="pet-info-text">
                  <span><%= req.pet.breed %></span>
                  <span class="separator">•</span>
                  <span><%= req.pet.age %> <%= req.pet.age == 1 ? 'year' : 'years' %></span>
                </div>
              </div>

              <!-- Status Badges -->
              <div class="badge-row">
                <span class="request-type-badge">
                  <%= req.request_type == 'adopt' ? '🏠' : '💝' %> <%= req.request_type.upcase %>
                </span>
                <span class="status-badge <%= case req.status
                    when 'open' then 'status-pending'
                    when 'approved' then 'status-approved'
                    when 'rejected' then 'status-rejected'
                    when 'scheduled' then 'status-scheduled'
                    when 'completed' then 'status-completed'
                    else 'status-pending'
                    end %>">
                  <%= req.status == 'open' ? 'PENDING' : req.status.upcase %>
                </span>
              </div>

              <!-- Status Text -->
              <div class="status-text">
                <% if req.open? %>
                  <span class="awaiting-text">
                    ⏳ Awaiting Review
                  </span>
                <% elsif req.approved? %>
                  <span class="awaiting-text approved">
                    ✓ Approved
                  </span>
                <% elsif req.completed? %>
                  <span class="awaiting-text completed">
                    ✓ Completed
                  </span>
                <% elsif req.rejected? %>
                  <span class="awaiting-text rejected">
                    ✗ Rejected
                  </span>
                <% end %>
              </div>

              <!-- Action Button -->
              <%= link_to request_path(req), class: 'view-details-btn' do %>
                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                </svg>
                View Details
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const filterTabs = document.querySelectorAll('.filter-tab');
        const requestCards = document.querySelectorAll('#requests-container > div');

        filterTabs.forEach(tab => {
          tab.addEventListener('click', function() {
            const filter = this.getAttribute('data-filter');

            // Update active tab
            filterTabs.forEach(t => t.classList.remove('active'));
            this.classList.add('active');

            // Filter cards
            requestCards.forEach(card => {
              const cardStatus = card.getAttribute('data-status');
              let shouldShow = false;

              if (filter === 'all') {
                shouldShow = true;
              } else if (filter === 'in-progress') {
                shouldShow = ['open', 'approved', 'scheduled', 'rejected'].includes(cardStatus);
              } else if (filter === 'completed') {
                shouldShow = cardStatus === 'completed';
              }

              if (shouldShow) {
                card.style.display = 'block';
                setTimeout(() => card.style.opacity = '1', 10);
              } else {
                card.style.opacity = '0';
                setTimeout(() => card.style.display = 'none', 300);
              }
            });
          });
        });
      });
    </script>

  <% else %>
    <!-- Beautiful Empty State Section -->
    <div class="empty-state">
      <div class="empty-icon-group">
        <span class="empty-icon">🐕</span>
        <span class="empty-icon">🦴</span>
        <span class="empty-icon">🐈</span>
      </div>

      <h2 class="empty-title">Your Journey Begins Here</h2>
      <p class="empty-description">
        You haven't made any adoption requests yet. Discover your perfect furry companion and start your journey to bringing home a new best friend!
      </p>

      <div class="empty-actions">
        <%= link_to pets_path, class: 'browse-pets-btn-primary' do %>
          <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <span>Find Your Perfect Pet</span>
        <% end %>

        <p class="empty-hint">
          <span>✨</span>
          <span>Over <%= Pet.available.count %> pets waiting for their forever home</span>
        </p>
      </div>
    </div>
  <% end %>
</div>
</div>
