<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; background-color: #f3f4f6;">
  <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f3f4f6;">
    <tr>
      <td style="padding: 20px; text-align: center;">
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">

          <!-- Header -->
          <tr>
            <td style="background: linear-gradient(135deg, #4F46E5 0%, #6366f1 100%); padding: 40px 20px; text-align: center; border-radius: 8px 8px 0 0;">
              <h1 style="margin: 0; color: #ffffff; font-size: 28px; font-weight: 700;">🐾 Pet Haven Hub</h1>
              <p style="margin: 8px 0 0; color: rgba(255,255,255,0.9); font-size: 14px;">Your Adoption Journey Begins</p>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding: 40px 30px;">

              <!-- Greeting -->
              <h2 style="margin: 0 0 20px; color: #1f2937; font-size: 24px; font-weight: 600;">
                Thank You, <%= @user.name %>!
              </h2>

              <!-- Message -->
              <p style="margin: 0 0 20px; color: #4b5563; font-size: 16px; line-height: 1.6;">
                Your <%= @request_type %> request for <strong style="color: #1f2937;"><%= @pet.name %></strong> has been received! 🎉
              </p>

              <!-- Request Details Card -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f9fafb; border-radius: 6px; border-left: 4px solid #4F46E5; margin-bottom: 30px;">
                <tr>
                  <td style="padding: 20px;">
                    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                      <tr>
                        <td style="padding-bottom: 12px;">
                          <p style="margin: 0; color: #6b7280; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Pet Details</p>
                          <p style="margin: 6px 0 0; color: #1f2937; font-size: 18px; font-weight: 600;"><%= @pet.name %></p>
                        </td>
                      </tr>
                      <tr>
                        <td style="padding-bottom: 12px;">
                          <p style="margin: 0; color: #6b7280; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Type & Details</p>
                          <p style="margin: 6px 0 0; color: #4b5563; font-size: 14px;">
                            <%= @pet.pet_type&.capitalize %><% if @pet.breed.present? %> • <%= @pet.breed %><% end %><% if @pet.age.present? %> • <%= @pet.age %> years<% end %>
                          </p>
                        </td>
                      </tr>
                      <tr>
                        <td>
                          <p style="margin: 0; color: #6b7280; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Request Type</p>
                          <p style="margin: 6px 0 0; color: #4b5563; font-size: 14px;"><%= @request_type %></p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- What Happens Next -->
              <p style="margin: 0 0 20px; color: #1f2937; font-size: 16px; font-weight: 600;">What Happens Next?</p>
              <p style="margin: 0 0 20px; color: #4b5563; font-size: 14px; line-height: 1.6;">
                Our team will carefully review your request to ensure the best match between you and <%= @pet.name %>.
                We'll contact you within 48 hours with an update on your application.
              </p>

              <!-- Timeline -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f0fdf4; border-radius: 6px; margin-bottom: 30px;">
                <tr>
                  <td style="padding: 20px;">
                    <ol style="margin: 0; padding-left: 20px; color: #1f2937;">
                      <li style="margin-bottom: 10px; line-height: 1.6;"><strong>Application Review:</strong> Our team reviews your details</li>
                      <li style="margin-bottom: 10px; line-height: 1.6;"><strong>Home Check:</strong> If needed, we may conduct a home check</li>
                      <li style="margin-bottom: 10px; line-height: 1.6;"><strong>Decision:</strong> We'll notify you of approval/rejection</li>
                      <li style="line-height: 1.6;"><strong>Next Steps:</strong> Finalize adoption if approved</li>
                    </ol>
                  </td>
                </tr>
              </table>

              <!-- CTA Button -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 30px;">
                <tr>
                  <td style="text-align: center;">
                    <a href="<%= requests_url %>" style="display: inline-block; padding: 14px 32px; background: linear-gradient(135deg, #4F46E5 0%, #6366f1 100%); color: #ffffff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 14px;">
                      View My Requests
                    </a>
                  </td>
                </tr>
              </table>

              <!-- Questions Section -->
              <p style="margin: 0 0 8px; color: #1f2937; font-size: 14px; font-weight: 600;">Have questions?</p>
              <p style="margin: 0; color: #4b5563; font-size: 14px;">
                Contact our support team at <a href="mailto:<%= ENV.fetch('ADMIN_EMAIL', 'support@pethavenhub.com') %>" style="color: #4F46E5; text-decoration: none;"><%= ENV.fetch('ADMIN_EMAIL', 'support@pethavenhub.com') %></a>
              </p>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color: #f9fafb; padding: 30px; border-radius: 0 0 8px 8px; border-top: 1px solid #e5e7eb;">
              <p style="margin: 0 0 12px; color: #6b7280; font-size: 14px; line-height: 1.6;">
                <strong style="color: #1f2937;">Pet Haven Hub</strong><br>
                Panauti, Kathmandu, Nepal
              </p>
              <p style="margin: 0 0 12px; color: #6b7280; font-size: 12px;">
                © <%= Time.current.year %> Pet Haven Hub. All rights reserved.
              </p>
              <p style="margin: 0; color: #9ca3af; font-size: 12px;">
                This is an automated message from our adoption system. Please do not reply directly to this email.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
