<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; background-color: #f3f4f6;">
  <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f3f4f6;">
    <tr>
      <td style="padding: 20px; text-align: center;">
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">

          <!-- Header -->
          <tr>
            <td style="background: linear-gradient(135deg, #d97706 0%, #f59e0b 100%); padding: 40px 20px; text-align: center; border-radius: 8px 8px 0 0;">
              <h1 style="margin: 0; color: #ffffff; font-size: 28px; font-weight: 700;">⏳ Request Update</h1>
              <p style="margin: 8px 0 0; color: rgba(255,255,255,0.9); font-size: 14px;">Your <%= @request_type %> Request is Being Reviewed</p>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding: 40px 30px;">

              <!-- Greeting -->
              <h2 style="margin: 0 0 20px; color: #1f2937; font-size: 24px; font-weight: 600;">
                Hello, <%= @user.name %>!
              </h2>

              <!-- Message -->
              <p style="margin: 0 0 24px; color: #4b5563; font-size: 16px; line-height: 1.6;">
                We wanted to let you know that your <%= @request_type %> request for
                <strong style="color: #d97706;"><%= @pet.name %></strong> is still being reviewed.
                It has been <strong><%= @days %> <%= @days == 1 ? 'day' : 'days' %></strong> since you submitted your request.
              </p>

              <!-- Status Card -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #fef3c7; border-radius: 6px; border-left: 4px solid #d97706; margin-bottom: 24px;">
                <tr>
                  <td style="padding: 20px;">
                    <p style="margin: 0 0 8px; color: #92400e; font-size: 14px; font-weight: 600;">Pet Under Review</p>
                    <p style="margin: 0; color: #92400e; font-size: 16px; font-weight: 500;"><%= @pet.name %></p>
                    <p style="margin: 8px 0 0; color: #92400e; font-size: 13px;">
                      <%= @pet.pet_type&.capitalize %><% if @pet.breed.present? %> • <%= @pet.breed %><% end %>
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Info Box -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f9fafb; border-radius: 6px; border: 1px solid #e5e7eb; margin-bottom: 30px;">
                <tr>
                  <td style="padding: 20px;">
                    <p style="margin: 0 0 12px; color: #1f2937; font-size: 14px; font-weight: 600;">Why This Takes Time</p>
                    <p style="margin: 0; color: #4b5563; font-size: 14px; line-height: 1.6;">
                      Our team carefully reviews each adoption request to ensure the best match between pets and their new families.
                      We appreciate your patience during this process. Most decisions are made within 5-7 business days.
                    </p>
                  </td>
                </tr>
              </table>

              <!-- CTA Button -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 30px;">
                <tr>
                  <td style="text-align: center;">
                    <a href="<%= requests_url %>" style="display: inline-block; padding: 14px 32px; background: linear-gradient(135deg, #d97706 0%, #f59e0b 100%); color: #ffffff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 14px;">
                      Check Request Status
                    </a>
                  </td>
                </tr>
              </table>

              <!-- Next Steps -->
              <p style="margin: 0 0 12px; color: #1f2937; font-size: 14px; font-weight: 600;">What's Next?</p>
              <p style="margin: 0; color: #4b5563; font-size: 14px; line-height: 1.6;">
                You'll receive an email notification as soon as there's an update on your request.
                If you have any questions in the meantime, feel free to reach out to us.
              </p>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color: #f9fafb; padding: 30px; border-radius: 0 0 8px 8px; border-top: 1px solid #e5e7eb;">
              <p style="margin: 0 0 12px; color: #6b7280; font-size: 14px; line-height: 1.6;">
                <strong style="color: #1f2937;">Pet Haven Hub</strong><br>
                Panauti, Kathmandu, Nepal
              </p>
              <p style="margin: 0 0 12px; color: #6b7280; font-size: 12px;">
                © <%= Time.current.year %> Pet Haven Hub. All rights reserved.
              </p>
              <p style="margin: 0; color: #9ca3af; font-size: 12px;">
                This is an automated message from our adoption system. Please do not reply directly to this email.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
