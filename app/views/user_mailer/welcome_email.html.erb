<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; background-color: #f3f4f6;">
  <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f3f4f6;">
    <tr>
      <td style="padding: 20px; text-align: center;">
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
          <tr>
            <td style="background: linear-gradient(135deg, #4F46E5 0%, #6366f1 100%); padding: 40px 20px; text-align: center; border-radius: 8px 8px 0 0;">
              <h1 style="margin: 0; color: #ffffff; font-size: 32px; font-weight: 700;">🐾 Welcome!</h1>
              <p style="margin: 8px 0 0; color: rgba(255,255,255,0.9); font-size: 14px;">Your Pet Adoption Journey Begins Here</p>
            </td>
          </tr>
          <tr>
            <td style="padding: 40px 30px;">
              <h2 style="margin: 0 0 20px; color: #1f2937; font-size: 24px; font-weight: 600;">Welcome, <%= @user.name %>!</h2>
              <p style="margin: 0 0 24px; color: #4b5563; font-size: 16px; line-height: 1.6;">
                Thank you for joining Pet Haven Hub! We're excited to help you find your perfect furry companion.
                Start exploring our collection of wonderful pets ready for their forever homes.
              </p>
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f0f4ff; border-radius: 6px; border-left: 4px solid #4F46E5; margin-bottom: 30px;">
                <tr>
                  <td style="padding: 20px;">
                    <ol style="margin: 0; padding-left: 20px; color: #1f2937; font-size: 14px; line-height: 1.8;">
                      <li style="margin-bottom: 12px;"><strong>Browse Pets:</strong> Explore our available pets and find one that matches your lifestyle</li>
                      <li style="margin-bottom: 12px;"><strong>Submit Request:</strong> Submit an adoption request for your favorite pet</li>
                      <li style="margin-bottom: 12px;"><strong>Review Process:</strong> Our team will review your application carefully</li>
                      <li><strong>Adopt!</strong> Once approved, finalize the adoption and welcome your new family member</li>
                    </ol>
                  </td>
                </tr>
              </table>
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 30px;">
                <tr>
                  <td style="text-align: center;">
                    <a href="<%= @url %>" style="display: inline-block; padding: 14px 32px; background: linear-gradient(135deg, #4F46E5 0%, #6366f1 100%); color: #ffffff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 14px;">
                      Start Browsing Pets
                    </a>
                  </td>
                </tr>
              </table>
              <p style="margin: 0 0 12px; color: #1f2937; font-size: 14px; font-weight: 600;">Need Help?</p>
              <p style="margin: 0; color: #4b5563; font-size: 14px;">
                Contact our support team at <a href="mailto:<%= ENV.fetch('ADMIN_EMAIL', 'support@pethavenhub.com') %>" style="color: #4F46E5; text-decoration: none;"><%= ENV.fetch('ADMIN_EMAIL', 'support@pethavenhub.com') %></a>
              </p>
            </td>
          </tr>
          <tr>
            <td style="background-color: #f9fafb; padding: 30px; border-radius: 0 0 8px 8px; border-top: 1px solid #e5e7eb;">
              <p style="margin: 0 0 12px; color: #6b7280; font-size: 14px; line-height: 1.6;">
                <strong style="color: #1f2937;">Pet Haven Hub</strong><br>
                Panauti, Kathmandu, Nepal
              </p>
              <p style="margin: 0 0 12px; color: #6b7280; font-size: 12px;">
                © <%= Time.current.year %> Pet Haven Hub. All rights reserved.
              </p>
              <p style="margin: 0; color: #9ca3af; font-size: 12px;">
                This is an automated message from our adoption system.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
